<% layout("/layouts/boilerplate") %>
<body>
    <h3 class="mt-3 mb-3">Edit the details</h3>

    <form method="post" action="/listings/<%=list._id%>?_method=put" novalidate class="needs-validation"> 
    
    <div class="row mt-3">
        <div class="col-8 offset-2">
        <div>
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" value="<%=list.title%>" type="text" class="form-control" required>

            <div class="valid-feedback">
                Title looks good
            </div>
        </div>

        <br>
        <br>

        <div>
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" type="text" class="form-control" required><%=list.description%></textarea >

            <div class="invalid-feedback">Please enter short description</div>

        </div>
        
        <br>
        <br>

        <div>
            <label for="image" class="form-label">Image</label>
            <input name="listing[image][url]" value="<%=list.image.url%>" type="text" class="form-control" required>

            <div class="invalid-feedback"> please enter a valid link for image</div>
        </div>
        
        <br>
        <br>
    
    <div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" value="<%=list.price%>" type="number" class="form-control" required>

            <div class="invalid-feedback">Please enter a valid price</div>
        </div>
        
        <br>
        <br>

        <div class="mb-3 col-md-8">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" value="<%=list.location%>" type="text" class="form-control" required>

            <div class="invalid-feedback">Location should be valid</div>
        </div>
    </div>
        
        
        <br>
        <br>

        <div>
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" value="<%=list.country%>" type="text" class="form-control" required>

            <div class="invalid-feedback">Country should be valid</div>
        </div>
        
        <br>
        <br>

        <button class="btn btn-dark edit-btn">Edit</button>
        </div>
    </div>
        
    </form>
</body>
